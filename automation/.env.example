# Setlist.fm — required (tour history + MusicBrainz artist ids)
SETLISTFM_API_KEY=

# Last.fm — optional; enables listener/scrobble signal + genre tags.
# Without it, Last.fm enrichment is skipped (fields come back null).
LASTFM_API_KEY=

# Discogs — optional personal access token; raises the rate limit from
# 25 to 60 requests/min for the discography cross-check. Works unauthenticated.
DISCOGS_TOKEN=

# Deezer and TheAudioDB need no API key.

# Ticketmaster Discovery API — optional; confirms on-sale/announced tours
# (strongest possible touring signal). Free self-serve key at
# https://developer.ticketmaster.com. Without it, Ticketmaster enrichment is
# skipped (hasUpcomingEvents stays false).
TICKETMASTER_API_KEY=

# Contact/notification
MATTHEW_EMAIL=
